<% layout('layouts/boilerplate') %>
<div class="row">
  <h1 class="text-center">New Campground</h1>
  <div class="col-6 offset-4">
    <form action="/campgrounds" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" class="form-control" name="campground[title]" id="title" placeholder="Campground Title" required>
         <div class="valid-feedback">
      Looks good!
    </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input type="text" class="form-control" name="campground[location]" id="location" placeholder="Location" required>
         <div class="valid-feedback">
      Looks good!
    </div>
    <div class="mb-3">
  <label for="formFileMultiple" class="form-label"></label>
  <input class="form-control" type="file" id=""  name="image" multiple>
</div>

      </div>


      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <input type="text" class="form-control" name="campground[description]" id="description" placeholder="Description" required>
         <div class="valid-feedback">
      Looks good!
    </div>
      </div>

      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input type="number" class="form-control" name="campground[price]" id="price" placeholder="Price" required>
      
      </div>

      <button class="btn btn-primary">Add</button>
    </form>
  </div>
</div>


